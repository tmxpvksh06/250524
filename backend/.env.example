SUPABASE_SECRET_KEY=
# Supabase CLI 배포 전용 값입니다. Git에 커밋하지 마세요.
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=your_project_ref
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4-mini
DATA_GO_KR_SERVICE_KEY=optional_public_data_portal_service_key
